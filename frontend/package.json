{
  "name": "pizza-planet-frontend",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@11.1.2",
  "scripts": {
    "dev": "vite --host 127.0.0.1",
    "build": "vue-tsc -b && vite build",
    "preview": "vite preview --host 127.0.0.1",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "XDG_CACHE_HOME=.cache ts-standard \"*.ts\" \"src/**/*.ts\" \"tests/**/*.ts\"",
    "typecheck": "vue-tsc -b"
  },
  "dependencies": {
    "vue": "^3.5.22",
    "vue-router": "^4.6.3"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^6.0.1",
    "@types/node": "^24.10.0",
    "@vue/test-utils": "^2.4.6",
    "autoprefixer": "^10.4.21",
    "happy-dom": "^20.0.10",
    "postcss": "^8.5.6",
    "tailwindcss": "^3.4.17",
    "ts-standard": "^12.0.2",
    "typescript": "^5.9.3",
    "vite": "^7.1.12",
    "vitest": "^4.0.7",
    "vue-tsc": "^3.1.2"
  },
  "ts-standard": {
    "project": "./tsconfig.lint.json"
  }
}
