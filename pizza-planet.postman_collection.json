{
  "info": {
    "_postman_id": "877d40bb-b215-4816-9837-8e9e14b46000",
    "name": "Pizza Planet API",
    "description": "Import with the Pizza Planet Local environment. Demo credentials are included in the environment.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Get CSRF Cookie",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const token = pm.cookies.get('XSRF-TOKEN');",
                  "if (token) {",
                  "  pm.environment.set('xsrf_token', decodeURIComponent(token));",
                  "}",
                  "",
                  "const setCookieHeaders = pm.response.headers.all()",
                  "  .filter((header) => header.key.toLowerCase() === 'set-cookie')",
                  "  .map((header) => header.value)",
                  "  .join('; ');",
                  "const headerToken = setCookieHeaders && setCookieHeaders.match(/XSRF-TOKEN=([^;]+)/);",
                  "if (headerToken) {",
                  "  pm.environment.set('xsrf_token', decodeURIComponent(headerToken[1]));",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Origin",
                "value": "{{frontend_origin}}"
              },
              {
                "key": "Accept",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{base_url}}/sanctum/csrf-cookie",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "sanctum",
                "csrf-cookie"
              ]
            }
          }
        },
        {
          "name": "Login",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Origin",
                "value": "{{frontend_origin}}"
              },
              {
                "key": "Accept",
                "value": "application/json"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{email}}\",\n  \"password\": \"{{password}}\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/{{api_version}}/sessions",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "{{api_version}}",
                "sessions"
              ]
            }
          }
        },
        {
          "name": "Current User",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Origin",
                "value": "{{frontend_origin}}"
              },
              {
                "key": "Accept",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/{{api_version}}/session",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "{{api_version}}",
                "session"
              ]
            }
          }
        },
        {
          "name": "Logout",
          "request": {
            "method": "DELETE",
            "header": [
              {
                "key": "Origin",
                "value": "{{frontend_origin}}"
              },
              {
                "key": "Accept",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/{{api_version}}/session",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "{{api_version}}",
                "session"
              ]
            }
          }
        }
      ]
    },
    {
      "name": "Orders",
      "item": [
        {
          "name": "List Orders",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const json = pm.response.json();",
                  "if (json.orders && json.orders.length > 0) {",
                  "  pm.environment.set('order_id', json.orders[0].id);",
                  "  if (json.orders[0].items && json.orders[0].items.length > 0) {",
                  "    pm.environment.set('item_id', json.orders[0].items[0].id);",
                  "  }",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Origin",
                "value": "{{frontend_origin}}"
              },
              {
                "key": "Accept",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/{{api_version}}/orders",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "{{api_version}}",
                "orders"
              ]
            }
          }
        },
        {
          "name": "Show Order",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Origin",
                "value": "{{frontend_origin}}"
              },
              {
                "key": "Accept",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/{{api_version}}/orders/{{order_id}}",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "{{api_version}}",
                "orders",
                "{{order_id}}"
              ]
            }
          }
        },
        {
          "name": "Update Order Item Status",
          "request": {
            "method": "PATCH",
            "header": [
              {
                "key": "Origin",
                "value": "{{frontend_origin}}"
              },
              {
                "key": "Accept",
                "value": "application/json"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"status\": \"{{item_status}}\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/{{api_version}}/orders/{{order_id}}/items/{{item_id}}",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "{{api_version}}",
                "orders",
                "{{order_id}}",
                "items",
                "{{item_id}}"
              ]
            }
          }
        }
      ]
    }
  ],
  "auth": {
    "type": "noauth"
  },
  "event": [
    {
      "listen": "prerequest",
      "script": {
        "type": "text/javascript",
        "exec": [
          "const method = pm.request.method.toUpperCase();",
          "const stateChangingMethods = ['POST', 'PUT', 'PATCH', 'DELETE'];",
          "",
          "if (stateChangingMethods.includes(method)) {",
          "  const rawToken = pm.cookies.get('XSRF-TOKEN') || pm.environment.get('xsrf_token');",
          "",
          "  if (!rawToken) {",
          "    throw new Error('Run Auth / Get CSRF Cookie before this request so Postman has an XSRF-TOKEN cookie.');",
          "  }",
          "",
          "  const token = decodeURIComponent(rawToken);",
          "  pm.environment.set('xsrf_token', token);",
          "  pm.request.headers.upsert({",
          "    key: 'X-XSRF-TOKEN',",
          "    value: token",
          "  });",
          "}"
        ]
      }
    }
  ]
}
