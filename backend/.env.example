APP_NAME="Pizza Planet"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://127.0.0.1:8000
FRONTEND_URL=http://127.0.0.1:5173

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=pizza_planet
DB_USERNAME=pizza_planet
DB_PASSWORD=pizza_planet

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=redis
WEBHOOK_QUEUE_CONNECTION=redis
WEBHOOK_QUEUE=webhooks
WEBHOOK_SIGNATURE_HEADER=X-Pizza-Planet-Signature
WEBHOOK_TIMESTAMP_HEADER=X-Pizza-Planet-Timestamp
WEBHOOK_TIMEOUT_SECONDS=3
WEBHOOK_TRIES=3
WEBHOOK_VERIFY_SSL=true

CACHE_STORE=redis
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=predis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

WEBSITE_WEBHOOK_URL=https://website.example.test/webhooks/pizza-planet
WEBSITE_WEBHOOK_SECRET=local-placeholder-signing-secret
